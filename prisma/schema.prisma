generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id           String   @id @default(cuid())
  title        String   @unique
  description  String
  technologies String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  githubUrl    String?
  imageUrl     String?
  projectUrl   String?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hash
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
